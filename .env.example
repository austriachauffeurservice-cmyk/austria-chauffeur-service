# Supabase — Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Must be on a domain verified in Resend (Domains -> austriachauffeurservice.com)
RESEND_FROM_EMAIL=bookings@austriachauffeurservice.com
# Where new-booking notifications are sent (your inbox)
ADMIN_NOTIFICATION_EMAIL=

# Admin dashboard (/admin) protection
ADMIN_PASSWORD=
# Random long string used to sign the admin session cookie, e.g. output of:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Public contact email shown on the /contact page (optional)
NEXT_PUBLIC_CONTACT_EMAIL=booking@austriachauffeurservice.com
